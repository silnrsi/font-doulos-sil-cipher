    sub c uni0327 by uni0162.CommaStyle;
    sub c uni0327 by uni0163.CommaStyle;
    sub n uni0327 by scedilla.CommaStyle;
    sub n uni0327 by scedilla.CommaStyle.SC;
    sub n uni0327 by Scedilla.CommaStyle;
} ccmp11;
lookup ccmp12 {
    sub @ccmp6 by @ccmp7;
} ccmp12;
lookup ccmp15;
lookup ccmp17;
lookup ccmp28;
 language VIT  exclude_dflt; # Vietnamese
lookup ccmp5;
lookup ccmp8;
lookup ccmp9 {
lookupflag;
    sub uni0302 acutecomb by uni0302_acutecomb.VN;
    sub uni0302 hookabovecomb by uni0302_hookabovecomb.VN;
    sub uni0302 gravecomb by uni0302_gravecomb.VN;
    sub uni0302 tildecomb by uni0302_tildecomb.VN;
    sub uni0306 acutecomb by uni0306_acutecomb.VN;
    sub uni0306 gravecomb by uni0306_gravecomb.VN;
    sub uni0306 tildecomb by uni0306_tildecomb.VN;
    sub uni0306 hookabovecomb by uni0306_hookabovecomb.VN;
} ccmp9;
lookup ccmp10 {
lookupflag 0;
    sub @ccmp11 by @ccmp12;
} ccmp10;
lookup ccmp15;
lookup ccmp17;
lookup ccmp28;
 language IPPH;
 script cyrl; # Cyrillic
lookup ccmp5;
lookup ccmp8;
lookup ccmp15;
lookup ccmp17;
lookup ccmp28;
} ccmp;













































feature smcp { # Small Capitals
 # Latin
    sub @smcp1 by @smcp2;
 language ROM ; # Romanian
 language VIT ; # Vietnamese
 language IPPH;
 script cyrl; # Cyrillic
    sub @smcp1 by @smcp2;
} smcp;













































feature c2sc { # Small Capitals From Capitals
 # Latin
    sub @c2sc1 by @c2sc2;
 language ROM ; # Romanian
 language VIT ; # Vietnamese
 language IPPH;
 script cyrl; # Cyrillic
    sub @c2sc1 by @c2sc2;
} c2sc;













































