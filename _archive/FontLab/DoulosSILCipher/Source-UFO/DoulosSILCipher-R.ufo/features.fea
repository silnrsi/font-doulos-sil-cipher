feature liga { # Standard Ligatures
 # Latin
lookup liga35 {
    sub f f i by f_f_i;
    sub f f l by f_f_l;
    sub f f by f_f;
    sub f i by f_i;
    sub f l by f_l;
} liga35;
lookup liga37 {
    sub f f by f_f;
    sub f i by f_i;
    sub f l by f_l;
} liga37;
 language ROM ; # Romanian
 language IPPH;
} liga;













































