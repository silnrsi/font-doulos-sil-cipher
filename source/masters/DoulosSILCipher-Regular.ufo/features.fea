@U = [X eight five four nine one seven six three two emdash endash figuredash x hyphen space period periodcentered u1D112 uni02B9 u1D1B1 u1D1B2 uni2010 uni2015 uni2070 uni2074 uni2075 uni2076 uni2077 uni2078 uni2079 uni25CC];
@U_MarkBase = [uni0305 uni033F uni0307];
