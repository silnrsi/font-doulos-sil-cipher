#**********************************
#  Classes
#**********************************
@NoHalf = [uni0305 uni033F uni0332 uni0333];
@Half = [uni0305.half uni033F.half uni0332.half uni0333.half];
@NoTip = [u1D177 u1D178];
@TipAbv = [u1D177.TipAbv u1D178.TipAbv];
@TipBlw = [u1D177.TipBlw u1D178.TipBlw];
@NoLrg = [uni266D uni266E uni266F];
@Lrg = [uni266D.Lrg uni266E.Lrg uni266F.Lrg];
@HalfBase = [space hyphen period u1D112 periodcentered uni02B9];
#**********************************
#
# Copyright (c) 2026 SIL Global (https://www.sil.org)
# Released under the MIT License (https://opensource.org/licenses/MIT)
#
#**********************************
#**********************************
#  Language Systems
#**********************************
languagesystem DFLT dflt;
languagesystem latn dflt;
# Notes:
#   The lookups and then the features should be arranged and grouped into ordered passes
#   as the rendering engines (esp Harfbuzz) will execute them.
#   The boundaries between passes are indicated by the comment
#       # HB PAUSE
#   in the code.
#**********************************
# GSUB (Substitution) lookups
#**********************************
# HB PAUSE
#---  ccmp lookups  ---
# Font rendering check
#
# The following three lookups change "RenderingUnknown" to "RenderingOpenType"
lookup _FontCheck_Unknow {
    lookupflag IgnoreMarks;
    sub [U n k o w] by [O p e T y];
} _FontCheck_Unknow;

lookup _FontCheck_n {
    lookupflag IgnoreMarks;
    sub n by p e;
} _FontCheck_n;

lookup FontCheck {
    lookupflag IgnoreMarks;
    sub [R] e n d e r i n g U' lookup _FontCheck_Unknow n' lookup _FontCheck_Unknow k' lookup _FontCheck_Unknow n' o' lookup _FontCheck_Unknow w' lookup _FontCheck_Unknow n' lookup _FontCheck_n;
} FontCheck;

# HB PAUSE
lookup half_lkp {
    # 
    lookupflag 0;
    sub @NoHalf by @Half;
} half_lkp;

lookup half {
    # GSUB lookup 4, type 16 (Chaining Context)
    lookupflag 0;
    sub @HalfBase @NoHalf' lookup half_lkp;
} half;

# HB PAUSE
#---  end ccmp lookups  ---
#---  locl lookups not used ---
# HB PAUSE
#---  stch lookups  ---
#---  end stch lookups  ---
# HB PAUSE
#---  end rclt lookups  ---
# Language-independent shaping
# HB PAUSE
#--- remaining subs features (salt, cvxx, liga) ---
# Lookups for user-selectable features
#---  ssxx and cvxx lookups  ---
lookup chinese {
    # needed for ss01
    lookupflag IgnoreMarks;
    sub @NoTip by @TipBlw;
} chinese;

#---  ssxx and cvxx lookups  ---
#**********************************
#  GSUB FEATURES
#**********************************
# These are intended to be arranged in the order MS & HB engines execute.
# HB PAUSE
#---  ccmp feature (pass 3) ---
feature ccmp {
    # Glyph Composition/Decomposition
    lookup FontCheck;
    # 
    lookup half;
    # 
} ccmp;

# HB PAUSE
#---  stch feature (pass 2b) ---
# HB PAUSE
#---  locl feature (pass 3) not used ---
# HB PAUSE
#---  stch feature (pass 8 or 9) ---
# HB PAUSE
#---  calt feature (pass 9)  ---
# moved to rclt because Adobe Premiere was disabling calt
# HB PAUSE
#********************
# all remaining substitution features (dlig,salt, ssxx, cvxx, liga, aalt):
#********************
#---  Stylistic Sets feature (pass 10) ---
# HB PAUSE
feature ss01 {
        featureNames {
        name "Slur";
    };

    script DFLT;
    language dflt;
    lookup chinese;
    script latn;
    language dflt;
    lookup chinese;
} ss01;

#---  liga feature (pass 10) ---
# not used
#**********************************
#
# Copyright (c) 2026 SIL Global  (https://www.sil.org)
# Released under the MIT License (https://opensource.org/licenses/MIT)
#
#**********************************
# Three features are implemented: kern, mark, and mkmk. 
#
# As best we understand it, all shapers now work per the OT spec in regard to GPOS lookup order of 
# execution, namely that lookups for all enabled features are executed in one pass in lookup order.
#
# Note that prior to around September 2024, HarfBuzz executed mark attachment in a separate
# pass after all base adjustments, but this caused compatibility issues with CoreText and Uniscribe
# (see https://github.com/harfbuzz/harfbuzz/issues/4596)
# To make sure the newer Harfbuzz doesn't cause problems we now put all base-positioning lookups 
# (kern and, if we had it, curs) before any mark positioning lookups (mark, mkmk).
#**********************************
# GPOS (Positioning) lookups
#**********************************
#********************
# Mark-to-base positioning
lookup MarkToBase {
    lookupflag 0;
    pos base X <anchor 740 1870> mark @_A;
    pos base [eight five four nine one seven six three two zero] <anchor 612 1870> mark @_A;
    pos base emdash <anchor 985 1870> mark @_A;
    pos base endash <anchor 492 1870> mark @_A;
    pos base [figuredash x] <anchor 512 1870> mark @_A;
    pos base [hyphen period space] <anchor 305 1870> mark @_A;
    pos base periodcentered <anchor 306 1870> mark @_A;
    pos base [u1D112 uni02B9] <anchor 313 1870> mark @_A;
    pos base u1D1B1 <anchor 579 1870> mark @_A;
    pos base u1D1B2 <anchor 589 1870> mark @_A;
    pos base uni2010 <anchor 404 1870> mark @_A;
    pos base uni2015 <anchor 995 1870> mark @_A;
    pos base uni25CC <anchor 533 1870> mark @_A;
    pos base X <anchor 740 -100> mark @_L;
    pos base [eight five four nine one seven six three two zero] <anchor 612 -100> mark @_L;
    pos base emdash <anchor 985 -100> mark @_L;
    pos base endash <anchor 492 -100> mark @_L;
    pos base [figuredash x] <anchor 512 -100> mark @_L;
    pos base [hyphen space] <anchor 305 -100> mark @_L;
    pos base period <anchor 292 -100> mark @_L;
    pos base periodcentered <anchor 306 -100> mark @_L;
    pos base [u1D112 uni02B9] <anchor 313 -100> mark @_L;
    pos base u1D1B1 <anchor 579 -100> mark @_L;
    pos base u1D1B2 <anchor 589 -100> mark @_L;
    pos base uni2010 <anchor 404 -100> mark @_L;
    pos base uni2015 <anchor 995 -100> mark @_L;
    pos base uni2070 <anchor 369 750> mark @_L;
    pos base uni2074 <anchor 354 750> mark @_L;
    pos base uni2075 <anchor 356 750> mark @_L;
    pos base uni2076 <anchor 372 750> mark @_L;
    pos base uni2077 <anchor 362 750> mark @_L;
    pos base uni2078 <anchor 370 750> mark @_L;
    pos base uni2079 <anchor 367 750> mark @_L;
    pos base uni25CC <anchor 533 -100> mark @_L;
    pos base X <anchor 740 1435> mark @_U;
    pos base [eight five four nine one seven six three two] <anchor 612 1435> mark @_U;
    pos base emdash <anchor 985 1435> mark @_U;
    pos base endash <anchor 536 767> mark @_U;
    pos base [figuredash x] <anchor 512 1435> mark @_U;
    pos base [hyphen space] <anchor 305 1435> mark @_U;
    pos base period <anchor 305 1455> mark @_U;
    pos base periodcentered <anchor 306 1435> mark @_U;
    pos base [u1D112 uni02B9] <anchor 313 1435> mark @_U;
    pos base u1D1B1 <anchor 579 1435> mark @_U;
    pos base u1D1B2 <anchor 589 1435> mark @_U;
    pos base uni2010 <anchor 404 1435> mark @_U;
    pos base uni2015 <anchor 995 1435> mark @_U;
    pos base uni2070 <anchor 369 1625> mark @_U;
    pos base uni2074 <anchor 354 1625> mark @_U;
    pos base uni2075 <anchor 356 1625> mark @_U;
    pos base uni2076 <anchor 372 1625> mark @_U;
    pos base uni2077 <anchor 362 1625> mark @_U;
    pos base uni2078 <anchor 370 1625> mark @_U;
    pos base uni2079 <anchor 367 1625> mark @_U;
    pos base uni25CC <anchor 533 1435> mark @_U;
    pos base [eight five four nine one seven six three] <anchor 612 695> mark @_C;
    pos base hyphen <anchor 305 695> mark @_C;
    pos base period <anchor 305 715> mark @_C;
    pos base periodcentered <anchor 306 695> mark @_C;
    pos base space <anchor 295 695> mark @_C;
    pos base two <anchor 562 695> mark @_C;
    pos base u1D1B1 <anchor 579 695> mark @_C;
    pos base u1D1B2 <anchor 589 695> mark @_C;
    pos base uni25CC <anchor 533 695> mark @_C;
} MarkToBase;

#********************
# Mark-to-mark attachment
@MarkFilter_A = [@A @_A];
lookup MarkToMarkAbove {
    lookupflag UseMarkFilteringSet @MarkFilter_A;
    pos mark X <anchor 740 1870> mark @_A;
    pos mark [eight five four nine one seven six three two zero] <anchor 612 1870> mark @_A;
    pos mark emdash <anchor 985 1870> mark @_A;
    pos mark endash <anchor 492 1870> mark @_A;
    pos mark [figuredash x] <anchor 512 1870> mark @_A;
    pos mark [hyphen period space] <anchor 305 1870> mark @_A;
    pos mark periodcentered <anchor 306 1870> mark @_A;
    pos mark [u1D112 uni02B9] <anchor 313 1870> mark @_A;
    pos mark u1D1B1 <anchor 579 1870> mark @_A;
    pos mark u1D1B2 <anchor 589 1870> mark @_A;
    pos mark uni2010 <anchor 404 1870> mark @_A;
    pos mark uni2015 <anchor 995 1870> mark @_A;
    pos mark uni25CC <anchor 533 1870> mark @_A;
} MarkToMarkAbove;

