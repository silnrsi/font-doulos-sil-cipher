#********************
# Base positioning (kerning) 
#**********************************
#********************
# Mark-to-base positioning
# Attach marks last, so they get positioned correctly on glyphs that have been shifted up.
feature mark {
    # Mark to base Positioning
    lookup MarkToBase;
} mark;

